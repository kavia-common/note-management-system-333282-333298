{"is_source_file": true, "format": "bash script", "description": "This script performs database backups by detecting the type of database (SQLite, PostgreSQL, MySQL, or MongoDB) running on the system, then executing the appropriate backup commands. It includes checks for specific database instances and handles different connection methods.", "external_files": ["/usr/lib/postgresql/", "/var/run/mysqld/mysqld.sock"], "external_methods": ["ls", "cp", "sudo -u postgres pg_isready", "ls", "mongosh", "mysqldump", "mysqladmin", "mysql"], "published": [], "classes": [], "methods": [], "calls": ["ls", "cp", "sudo -u postgres pg_isready", "mongosh --port ${DB_PORT} --eval \"db.adminCommand('ping')\"", "mongodump --port ${DB_PORT} --db ${DB_NAME} --archive=database_backup.archive --quiet", "mysqladmin ping -h localhost -P ${DB_PORT} --silent", "sudo mysqladmin ping --socket=/var/run/mysqld/mysqld.sock --silent", "mysql -h localhost -P ${DB_PORT} -u ${DB_USER} -p${DB_PASSWORD} -e \"SELECT 1\"", "mysqldump -h localhost -P ${DB_PORT} -u ${DB_USER} -p${DB_PASSWORD} --databases ${DB_NAME} --add-drop-database --routines --triggers --single-transaction", "mysql -h localhost -P ${DB_PORT} -u root -p${DB_PASSWORD} -e \"SELECT 1\"", "sudo mysqldump --socket=/var/run/mysqld/mysqld.sock -u root -p${DB_PASSWORD} --databases ${DB_NAME} --add-drop-database --routines --triggers --single-transaction", "sudo mysql --socket=/var/run/mysqld/mysqld.sock -u root -e \"SELECT 1\""], "search-terms": ["backup_db.sh", "database backup", "SQLite", "PostgreSQL", "MySQL", "MongoDB", "db isready", "mysqldump", "mongodump", "pg_dump"], "state": 2, "file_id": 1, "knowledge_revision": 18, "git_revision": "78bf3f1a013601f34ab00e5bc6a57daeafdb6075", "hash": "d7da372b768c895a33088027314656c3", "format-version": 4, "code-base-name": "database", "filename": "database/backup_db.sh", "revision_history": [{"18": "78bf3f1a013601f34ab00e5bc6a57daeafdb6075"}]}